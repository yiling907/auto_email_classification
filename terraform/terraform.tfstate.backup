    {
      "mode": "managed",
      "type": "aws_sfn_state_machine",
      "name": "gmail_processing",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:states:us-east-1:970850578809:stateMachine:gmail-processing-state-machine",
            "creation_date": "2026-02-23T19:51:12Z",
            "definition": "{\n  \"Comment\": \"Gmail email processing workflow: parse, AI analyze, extract, save\",\n  \"StartAt\": \"ParseEmailBasicInfo\",\n  \"States\": {\n    \"ParseEmailBasicInfo\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:lambda:us-east-1:970850578809:function:gmail-processing-parse-email\",\n      \"Retry\": [\n        {\n          \"ErrorEquals\": [\"Lambda.ServiceException\", \"Lambda.AWSLambdaException\"],\n          \"IntervalSeconds\": 2,\n          \"MaxAttempts\": 3,\n          \"BackoffRate\": 2\n        }\n      ],\n      \"Catch\": [\n        {\n          \"ErrorEquals\": [\"States.ALL\"],\n          \"Next\": \"ProcessFailure\"\n        }\n      ],\n      \"Next\": \"InvokeBedrockModel\"\n    },\n    \"InvokeBedrockModel\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:lambda:us-east-1:970850578809:function:gmail-processing-invoke-bedrock\",\n      \"Retry\": [\n        {\n          \"ErrorEquals\": [\"Lambda.ServiceException\"],\n          \"IntervalSeconds\": 3,\n          \"MaxAttempts\": 2\n        }\n      ],\n      \"Catch\": [\n        {\n          \"ErrorEquals\": [\"States.ALL\"],\n          \"Next\": \"ProcessFailure\"\n        }\n      ],\n      \"Next\": \"ExtractBusinessInfo\"\n    },\n    \"ExtractBusinessInfo\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:lambda:us-east-1:970850578809:function:gmail-processing-extract-business\",\n      \"Retry\": [\n        {\n          \"ErrorEquals\": [\"Lambda.ServiceException\"],\n          \"IntervalSeconds\": 2,\n          \"MaxAttempts\": 3\n        }\n      ],\n      \"Catch\": [\n        {\n          \"ErrorEquals\": [\"States.ALL\"],\n          \"Next\": \"ProcessFailure\"\n        }\n      ],\n      \"Next\": \"SaveToDynamoDB\"\n    },\n    \"SaveToDynamoDB\": {\n      \"Type\": \"Task\",\n      \"Resource\": \"arn:aws:lambda:us-east-1:970850578809:function:gmail-processing-save-to-dynamodb\",\n      \"Catch\": [\n        {\n          \"ErrorEquals\": [\"States.ALL\"],\n          \"Next\": \"ProcessFailure\"\n        }\n      ],\n      \"Next\": \"ProcessSuccess\"\n    },\n    \"ProcessSuccess\": {\n      \"Type\": \"Succeed\",\n      \"Comment\": \"Email processing completed successfully\"\n    },\n    \"ProcessFailure\": {\n      \"Type\": \"Fail\",\n      \"Error\": \"ProcessingFailed\",\n      \"Cause\": \"Workflow failed at one or more steps\"\n    }\n  }\n}",
            "description": "",
            "encryption_configuration": [
